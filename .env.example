# Скопируйте в .env при локальном запуске без Docker.
APP_NAME=QA Training Platform
ENVIRONMENT=development
DEBUG=true

# Локально (без Docker) удобно использовать SQLite:
DATABASE_URL=sqlite:///./qatp.db
# В Docker используется PostgreSQL:
# DATABASE_URL=postgresql+psycopg://qatp:qatp@db:5432/qatp

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
